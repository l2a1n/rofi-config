 /* wallust template - colors-rofi */

* {
active-background: #D96E83;
active-foreground: #FAF1EF;
normal-background: #19191F;
normal-foreground: #FAF1EF;
urgent-background: #299BC0;
urgent-foreground: #FAF1EF;

alternate-active-background: #B45E74;
alternate-active-foreground: #FAF1EF;
alternate-normal-background: #19191F;
alternate-normal-foreground: #FAF1EF;
alternate-urgent-background: #19191F;
alternate-urgent-foreground: #FAF1EF;

selected-active-background: #D96E83;
selected-active-foreground: #19191F;
selected-normal-background: #D96E83;
selected-normal-foreground: #19191F;
selected-urgent-background: #B45E74;
