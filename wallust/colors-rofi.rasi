background-color: #19191F;
background: rgba(0,0,0,0.7);
foreground: #FAF1EF;
border-color: #D96E83;

color0: #404046;
color1: #18152B;
color2: #502E41;
color3: #874657;
color4: #A35262;
color5: #1F7490;
color6: #B5A29E;
color7: #F0E3E0;
color8: #A89F9D;
